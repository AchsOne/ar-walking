<!-- Ergänzung für AndroidManifest.xml -->
<!-- Füge diese Zeilen in deine bestehende AndroidManifest.xml ein -->

<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- AR-Permissions -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature 
        android:name="android.hardware.camera.ar" 
        android:required="true" />
    
    <!-- ARCore Required -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="true" />
    
    <application>
        
        <!-- Neue Snapchat-Style AR Navigation Activity -->
        <activity
            android:name=".ar.ARNavigationActivity"
            android:exported="true"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar"
            android:screenOrientation="portrait"
            android:configChanges="orientation|keyboardHidden|screenSize">
            
            <!-- Optional: Als Launcher-Activity setzen für direkten Start -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <!-- ARCore Metadata -->
        <meta-data 
            android:name="com.google.ar.core" 
            android:value="required" />
            
    </application>
    
</manifest>